JWT_SECRET=change-me
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DEV_AUTH_BYPASS=false

LLM_BASE_URL=https://api.mistral.ai/v1
LLM_API_KEY=
CHAT_BASE_URL=https://api.mistral.ai/v1
CHAT_API_KEY=
CHAT_MODEL=mistral-small-latest
VLM_BASE_URL=https://api.mistral.ai/v1
VLM_API_KEY=
VLM_ENABLED=false

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/math_tutor
REDIS_URL=redis://redis:6379/0

# Optional local override for tests/dev outside containers
STORAGE_DIR=
DISABLE_RQ_ENQUEUE=false

# Optional: route Manim render through manim-mcp-server
MANIM_RENDER_BACKEND=local
MANIM_MCP_COMMAND=
# Examples:
# 1) space-delimited args:
# MANIM_MCP_ARGS=/opt/manim-mcp-server/src/manim_server.py
# 2) JSON array args:
# MANIM_MCP_ARGS=["/opt/manim-mcp-server/src/manim_server.py"]
MANIM_MCP_ARGS=
# Directory used by manim-mcp-server for generated media (contains mp4 outputs)
MANIM_MCP_MEDIA_DIR=
MANIM_MCP_TIMEOUT_SECONDS=240
MANIM_MCP_SERVER_DIR=./manim-mcp-server
